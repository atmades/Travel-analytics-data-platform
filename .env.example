# =========================
# Kafka
# =========================

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

USER_EVENTS_TOPIC=user.events.avro
USER_EVENTS_GROUP_ID=user-event-clickhouse-consumer-observability-v4

ORDERS_CDC_TOPIC=orders.public.orders
ORDERS_CDC_GROUP_ID=orders-cdc-clickhouse-consumer

# =========================
# Schema Registry
# =========================

SCHEMA_REGISTRY_URL=http://schema_registry:8081

# =========================
# ClickHouse
# =========================

CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=travel_user
CLICKHOUSE_PASSWORD=travel_password

# =========================
# Airflow
# =========================

AIRFLOW_UID=50000

# =========================
# OpenAI / AI Agent
# =========================

OPENAI_API_KEY=real_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# =========================
# Meta Ads API
# =========================

META_ACCESS_TOKEN=real_meta_access_token
META_AD_ACCOUNT_ID=real_meta_ad_account_id

# =========================
# Google Ads API
# =========================

GOOGLE_ADS_DEVELOPER_TOKEN=real_google_ads_developer_token
GOOGLE_ADS_CLIENT_ID=real_google_ads_client_id
GOOGLE_ADS_CLIENT_SECRET=real_google_ads_client_secret
GOOGLE_ADS_REFRESH_TOKEN=real_google_ads_refresh_token
GOOGLE_ADS_CUSTOMER_ID=real_google_ads_customer_id

# =========================
# Mock APIs
# =========================

ADS_API_MODE=mock

# =========================
# Observability
# =========================

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# =========================
# Kafka UI
# =========================

KAFKA_UI_PORT=8088

